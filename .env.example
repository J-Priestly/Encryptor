# GitHub Personal Access Token (needs 'repo' scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repository in "owner/repo" format
GITHUB_REPO=your-username/your-repo

# Ping mode: "issue" (creates GitHub issue) or "dispatch" (fires repository_dispatch event)
PING_MODE=issue

# Default encryption password (optional — can also use -p flag)
# ENCRYPT_PASSWORD=your-secure-password

# ─── DNS Canary Settings ───────────────────────────────────────
# Your canary domain (set NS records to point to your server)
CANARY_DOMAIN=canary.yourdomain.com

# HTTP canary server URL (where your canary server is reachable)
CANARY_HTTP_URL=http://your-server-ip:8053
